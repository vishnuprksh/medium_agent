# Daily Medium digest settings.
DIGEST_RECIPIENTS=vishnucheppanam@gmail.com
DIGEST_INTENT=Practical, non-hype articles about building useful AI agents with Python and product thinking.
DIGEST_TAGS=artificial-intelligence, ai-agents, python, software-development
DIGEST_SOURCES=
DIGEST_MAX_FEEDS=10
DIGEST_MAX_ITEMS_PER_FEED=20
DIGEST_TOP_K=8
DIGEST_INCLUDE_METRICS=false
DIGEST_MIN_CLAPS=0
DIGEST_MIN_RESPONSES=0
DIGEST_USE_OPENROUTER=true
DIGEST_DRY_RUN=false

# SMTP settings. For Gmail, use an app password instead of your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Optional. Without this key the cron job still works with local TF-IDF ranking.
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=

# Current defaults can be changed without editing code.
# Using tencent/hy3:free as the default model as requested
OPENROUTER_EMBEDDING_MODEL=tencent/hy3:free
OPENROUTER_CHAT_MODEL=tencent/hy3:free

# Put your real product/contact URL or email here before deploying.
APP_USER_AGENT=MediumAIReader/0.1 (+mailto:vishnucheppanam@gmail.com; respectful RSS discovery)
